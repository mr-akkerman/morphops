# ─── LLM ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-6

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=...
# Comma-separated Telegram user IDs allowed to use the bot.
# Leave empty to allow everyone (development only).
ALLOWED_USER_IDS=123456789

# ─── Agent directories ────────────────────────────────────────────────────────
# These are created automatically on startup if they don't exist.
AGENT_TOOLS_DIR=./agent_tools
AGENT_MCP_DIR=./agent_mcp
AGENT_CONTEXT_DIR=./agent_context
AGENT_TMP_DIR=./agent_tmp

# ─── Limits ───────────────────────────────────────────────────────────────────
MAX_TOOL_EXECUTION_TIME=30
MAX_AGENT_ITERATIONS=15

# ─── Security ─────────────────────────────────────────────────────────────────
MAX_HISTORY_PAIRS=30
MAX_INPUT_CHARS=8000
MAX_REQUESTS_PER_HOUR=40
MAX_CONTEXT_FILE_CHARS=20000
MAX_CONTEXT_TOTAL_CHARS=50000
# Set to true to restrict DB access to SELECT-only (useful for monitoring/analytics bots)
DB_READONLY=false
